[Unit]
Description=Ganglion-OOB Sentry Agent (Guest Production VM)
Documentation=https://github.com/yourorg/ganglion-oob
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/ganglion-oob/guest_production_vm
# Shared master secret (hex) — MUST match the controller's. Distribute securely
# (config management / secrets store). Keep mode 0600.
EnvironmentFile=-/etc/ganglion-oob/master.env
ExecStart=/usr/bin/python3 /opt/ganglion-oob/guest_production_vm/sentry_agent.py \
    --controller-host 192.168.20.1 \
    --controller-port 9999 \
    --target-dir /home \
    --entropy-threshold 7.2 \
    --poll-interval 2.0

Restart=always
RestartSec=3
StandardOutput=null
StandardError=null
SyslogIdentifier=ganglion-sentry

# Run silently — no TTY, no journal spam, no visibility to attacker
KillMode=process
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
